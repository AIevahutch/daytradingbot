<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.eva.trading-bot.dashboard</string>

  <key>WorkingDirectory</key>
  <string>/Users/eva/Documents/Day Trading Bot</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/eva/Documents/Day Trading Bot/.venv/bin/streamlit</string>
    <string>run</string>
    <string>/Users/eva/Documents/Day Trading Bot/dashboard/app.py</string>
    <string>--server.port</string>
    <string>8501</string>
  </array>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/eva/Documents/Day Trading Bot/logs/launchd-dashboard.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/eva/Documents/Day Trading Bot/logs/launchd-dashboard.err.log</string>
</dict>
</plist>
